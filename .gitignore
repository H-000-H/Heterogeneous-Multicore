# =============================================
# 编译构建目录
# =============================================
build/
build-ninja/
_build/

# =============================================
# CMake 生成文件
# =============================================
CMakeCache.txt
CMakeFiles/
compile_commands.json
*.ninja
*.ninja_deps
*.ninja_log

# =============================================
# 编译器产物（不应提交）
# =============================================
*.elf
*.map
*.lst
*.o
*.obj

# =============================================
# 缓存文件
# =============================================
.cache/
__pycache__/
*.pyc

# =============================================
# 日志文件
# =============================================
*.log

# =============================================
# 本地环境配置（每个人的编译环境路径不同，不该上传）
# =============================================
sdkconfig
sdkconfig.old
dependencies.lock

# =============================================
# 编辑器个人配置（仅忽略 IDE 生成的个人文件）
# 项目共享的 .vscode/ 配置文件不应在此忽略
# =============================================
.idea/
.cursor/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.code-workspace
