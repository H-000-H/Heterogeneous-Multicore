# 过滤整个编译输出目录（最核心，这一下就能干掉 6000 多个文件）
build/

# 过滤本地配置文件（每个人的编译环境路径不同，不该上传）
sdkconfig
sdkconfig.old
dependencies.lock

# 过滤编辑器本地配置
.vscode/
.idea/
.cursor/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 过滤临时或日志文件
*.log# 编译构建目录
build-ninja/
build/
_build/
# Clangd LSP缓存
.cache/
# Python字节码
__pycache__/
*.pyc
# VSCode工作区
*.code-workspace
# CMake生成文件
CMakeCache.txt
CMakeFiles/
compile_commands.json
*.ninja
*.ninja_deps
*.ninja_log
*.elf *.map *.lst
# 日志、临时文档
*.log
