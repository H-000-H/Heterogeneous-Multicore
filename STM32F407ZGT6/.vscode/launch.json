{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (J-link)",
            "type": "cortex-debug",
            "request": "launch",

            //根目录
            "cwd":"${workspaceFolder}",

            //elf debug模式
            "executable": "${workspaceFolder}/build/Debug/STM32F407ZGT6.elf",

            //调试前编译
            "preLaunchTask": "CMake Build Debug",

            "servertype": "jlink",

            "serverpath":  "D:/SEGGER/JLink/JLinkGDBServerCL.exe",

            "device": "STM32F407ZG",

            "runToEntryPoint": "stm32f407zgt6_node_main",

            "gdbPath": "C:/ST/STM32CubeCLT_1.20.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            //硬件复位 (默认行为, 无需显式设置)
            "showDevDebugOutput": "raw",
            "svdFile": "C:/Users/18514/AppData/Local/stm32cube/packs/STMicroelectronics/stm32f4xx_dfp/1.2.0/SVD/STM32F407.svd"
        }
    ]
}