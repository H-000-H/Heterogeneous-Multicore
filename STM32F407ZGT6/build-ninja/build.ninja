build cmake/stm32cubemx/all: phony cmake/stm32cubemx/STM32_Drivers

# =============================================================================

#############################################
# Folder: D:/can_project/STM32F407ZGT6/build-ninja/hal

build hal/all: phony hal/libstm32f407_hal.a

# =============================================================================

#############################################
# Folder: D:/can_project/STM32F407ZGT6/build-ninja/mini_tree

build mini_tree/all: phony mini_tree/libmini_tree.a

