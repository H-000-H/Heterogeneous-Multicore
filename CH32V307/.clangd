CompileFlags:
  Remove:
    - -fno-shrink-wrap
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-reorder-functions
    - -f*
    - -m*
    - -W*

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None

---
If:
  PathMatch: .*mini_tree[/\\].*\.(c|cpp|S)$
CompileFlags:
  # compile_commands 提供绝对 -I；另加 isystem 供 esp-clang 找到 stdio.h 等
  CompilationDatabase: build/Debug
  Add:
    - --target=riscv32-unknown-elf
    - -I../../../ESP32-S3/managed_components/marcel-cd__etlcpp/etl/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*hal_inst[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I../../hal_bus/include
    - -I.
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*hal_bus[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*hal_if[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I../../hal_bus/include
    - -I.
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*board[/\\]include[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.
    - -I../../core/include
    - -I../../osal/include
    - -I../../../build/Debug/generated/board/mini_tree
    - -I../../../build/Debug/generated/kconfig/mini_tree
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*osal[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.
    - -I../../core/include
    - -I../../lib/freeRTOS/include
    - -I../../lib/freeRTOS
    - -I../../lib/freeRTOS/portable/GCC/RISC-V
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/riscv32-wch-elf/include
    - -isystem
    - D:/MounRiver_Studio2/resources/app/resources/win32/components/WCH/Toolchain/RISC-V Embedded GCC15/lib/gcc/riscv32-wch-elf/15.2.0/include

---
If:
  PathMatch: .*[/\\]app[/\\].*\.(c|cpp|S)$
CompileFlags:
  CompilationDatabase: build/Debug
  Add:
    - -I../../../ESP32-S3/managed_components/marcel-cd__etlcpp/etl/include

---
