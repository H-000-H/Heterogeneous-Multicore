/*
 * CH32V307 UART
 *
 * Bindings:
 *   ch32,uart1 — vfs/uart/vfs-uart.c
 *
 * 时钟/GPIO：由 MounRiver MX_USART1_Init() 在 main pre_execution 钩子完成；
 * host-id 0 映射 USART1 (PA9 TX, PA10 RX)。
 */

#include "ch32v307.dtsi"
#include <dt-bindings/uart/uart-parameter.h>
#include <dt-bindings/gpio/gpio-ctl.h>

&soc {
	uart_cap: uart-cap {
		compatible = "ch32,uart-platform-cap";
		mini-tree,platform;
		host-max = <1>;
		max-xfer = <512>;
		timeout-ms = <10>;
	};

	uart1: uart@0 {
		compatible = "ch32,uart1";
		reg = <0>;
		host-id = <0>;
		tx-port = <DTS_GPIOA>;
		tx-pin = <DTS_GPIO_PIN_9>;
		rx-port = <DTS_GPIOA>;
		rx-pin = <DTS_GPIO_PIN_10>;
		uart-trans-baund = <115200>;
		data-bit = <8>;
		stop-bit = <0>;
		parity = <0>;
		status = "okay";
	};
};
