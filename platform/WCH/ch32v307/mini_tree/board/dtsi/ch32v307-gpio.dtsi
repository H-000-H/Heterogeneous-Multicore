/*
 * CH32V307 GPIO — SoC default parameters
 *
 * Board-specific port/pin/mode/pull in board *.dts &gpios_pin { }.
 * Bindings:
 *   ch32,gpio              — GPIO 控制器 (平台节点, 无 DRIVER_REGISTER)
 *   heterogeneous,gpios    — 单引脚配置实例 → vfs/gpio/vfs-gpio.c
 */

#include "ch32v307.dtsi"
#include <dt-bindings/gpio/gpio-ctl.h>

&soc {
	gpio: gpio@0 {
		compatible = "ch32,gpio";
		reg = <0>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "okay";
	};

	gpios_pin: gpios-pin@0 {
		compatible = "heterogeneous,gpios";
		reg = <0>;
		gpio-port = <DTS_GPIOA>;
		gpio-pin = <DTS_GPIO_PIN_0>;
		gpio-mode = <DTS_GPIO_DEFAULT_OUTPUT>;
		gpio-pull = <DTS_GPIO_DEFAULT_OUTPUT_PULL>;
		gpio-intr = <DTS_GPIO_DEFAULT_INTR>;
		default-level = <DTS_GPIO_DEFAULT_LEVEL>;
		status = "disabled";
	};
};
