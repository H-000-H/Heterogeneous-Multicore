CompileFlags:
  CompilationDatabase: build
  Add:
    - --target=riscv32-unknown-elf
    - -isystem
    - /opt/wch-toolchain/riscv-wch-elf/include
    - -isystem
    - /opt/wch-toolchain/lib/gcc/riscv-wch-elf/12.2.0/include
    - -isystem
    - /opt/wch-toolchain/lib/gcc/riscv-wch-elf/12.2.0/include-fixed
    - -isystem
    - /opt/wch-toolchain/riscv-wch-elf/include/c++/12.2.0
    - -isystem
    - /opt/wch-toolchain/riscv-wch-elf/include/c++/12.2.0/riscv-wch-elf
  Remove:
    - -fno-shrink-wrap
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-reorder-functions
    - -f*
    - -m*
    - -W*

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None

---
If:
  PathMatch: .*mini_tree[/\\].*\.(c|cpp|S)$
CompileFlags:
  # compile_commands 提供绝对 -I；fallback 时用绝对 -I（clangd 以源文件目录为 cwd）
  CompilationDatabase: build
  Add:
    - --target=riscv32-unknown-elf
    - -DCONFIG_OSAL_FREERTOS
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/algorithm/buffer
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/board/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/board/dt-bindings/gpio
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/bus/dma
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/bus/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/bus/spi
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/bus/uart
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/core/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/drivers/flash
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/drivers/ws2812
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/gpio
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/cpu
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/pwm
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/analog
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/storage
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/system
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/soc/ch32v307
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/spi
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/hal/uart
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/osal/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/system_c/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/system_cpp/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/vfs/gpio
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/vfs/spi
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/vfs/uart
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/SRC/Peripheral/inc
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/SRC/Core
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/SRC/Debug
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/SRC/User
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/lib/freeRTOS
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/lib/freeRTOS/include
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/mini_tree/lib/freeRTOS/portable/GCC/RISC-V
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/build/generated/board/mini_tree
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/build/generated/kconfig/mini_tree
    - -I/home/ning/project/Heterogeneous-Multicore/platform/WCH/ch32v307/build/generated/scrubber/mini_tree
    - -I/home/ning/project/Heterogeneous-Multicore/platform/Espressif/esp32s3/managed_components/marcel-cd__etlcpp/etl/include

---
If:
  PathMatch: .*hal_inst[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I../../hal_bus/include
    - -I.

---
If:
  PathMatch: .*hal_bus[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.

---
If:
  PathMatch: .*hal_if[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I../../hal_bus/include
    - -I.

---
If:
  PathMatch: .*board[/\\]include[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.
    - -I../../core/include
    - -I../../osal/include
    - -I../../../build/generated/board/mini_tree
    - -I../../../build/generated/kconfig/mini_tree

---
If:
  PathMatch: .*osal[/\\].*\.h$
CompileFlags:
  CompilationDatabase: None
  Add:
    - --target=riscv32-unknown-elf
    - -x
    - c-header
    - -std=gnu17
    - -DCONFIG_OSAL_FREERTOS
    - -I.
    - -I../../core/include
    - -I../../lib/freeRTOS/include
    - -I../../lib/freeRTOS
    - -I../../lib/freeRTOS/portable/GCC/RISC-V

---
If:
  PathMatch: .*[/\\]app[/\\].*\.(c|cpp|S)$
CompileFlags:
  CompilationDatabase: build
  Add:
    - -I/home/ning/project/Heterogeneous-Multicore/platform/Espressif/esp32s3/managed_components/marcel-cd__etlcpp/etl/include
