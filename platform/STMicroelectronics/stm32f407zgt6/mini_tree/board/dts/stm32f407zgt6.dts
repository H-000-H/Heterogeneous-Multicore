/*
 * STMicro STM32F407ZGT6 board
 *
 * dtc-lite 推荐布局 (无序全解耦版):
 *   1. /dts-v1/
 *   2. #include SoC + IP dtsi（可集中放在文件头）
 *   3. / { model, compatible, aliases }
 *   4. &label { 板级引脚 / gpio / status = "okay" }
 *
 * 常量宏在 board/dt-bindings/，由 IP dtsi #include；板级只覆写实例参数。
 */

/dts-v1/;

#include "stm32f407.dtsi"
#include "stm32f407-gpio.dtsi"
#include "stm32f407-dma.dtsi"
#include "stm32f407-spi.dtsi"
#include "stm32f407-uart.dtsi"

/chosen {
	tick-rate = <1000>;
	heap-size = <32768>;
};

/ {
	#address-cells = <1>;
	#size-cells = <0>;

	model = "STMicro STM32F407ZGT6";
	compatible = "st,stm32f407zgt6", "st,stm32f407";
};
