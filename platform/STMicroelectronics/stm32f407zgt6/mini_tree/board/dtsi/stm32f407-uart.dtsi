/*
 * STM32F407 UART
 *
 * Bindings:
 *   stm32,uart1 — bus/uart/uart_bus.c
 *
 * 时钟/GPIO：由 CubeMX MX_UART4_Init() 在 main pre_execution 钩子完成；
 * host-id 0 映射 UART4 (PA1 RX, PC10 TX)。
 */

#include "stm32f407.dtsi"
#include "stm32f407-dma.dtsi"
#include <dt-bindings/uart/uart-parameter.h>
#include <dt-bindings/hw/hw-instance.h>
#include <dt-bindings/gpio/gpio-ctl.h>

&soc {
	uart_cap: uart-cap {
		compatible = "stm32,uart-platform-cap";
		mini-tree,platform;
		host-max = <6>;			/* USART1/2/3 + UART4/5/6 */
		max-xfer = <512>;
		timeout-ms = <10>;
	};

	uart1: uart@0 {
		compatible = "stm32,uart1";
		reg = <0>;
		host-id = <0>;
		hw-instance = <DTS_HW_UART4>;
		dma-tx = <&dma_uart4_tx>;
		rx-port = <DTS_GPIOA>;
		rx-pin = <DTS_GPIO_PIN_1>;
		tx-port = <DTS_GPIOC>;
		tx-pin = <DTS_GPIO_PIN_10>;
		uart-trans-baund = <115200>;
		data-bit = <8>;
		stop-bit = <0>;
		parity = <0>;
		status = "okay";
	};
};
