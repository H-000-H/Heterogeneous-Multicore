
#
# mini_tree Configuration
#

#
# Platform
#
CONFIG_PLATFORM_XTENSA=y
# end of Platform

#
# Multi-core Configuration
#
CONFIG_CPU_CORES=1
# end of Multi-core Configuration

#
# OSAL Backend
#
CONFIG_OSAL_FREERTOS=y
# CONFIG_OSAL_RTTHREAD is not set
# CONFIG_OSAL_NULL is not set
# end of OSAL Backend

#
# System Log
#
CONFIG_SYS_LOG_USE_PRINTF=y
# CONFIG_SYS_LOG_USE_OSAL is not set
# CONFIG_SYS_LOG_USE_ESP is not set
# end of System Log

#
# System Backend
#
# CONFIG_SYSTEM_C is not set
CONFIG_SYSTEM_CPP=y
# end of System Backend

#
# Board Features
#
# CONFIG_PRODUCTION_LOG is not set
# CONFIG_SAFETY_SHUTDOWN is not set
CONFIG_ENABLE_WDT=y
CONFIG_ENABLE_FLASH_SCRUBBER=y
# end of Board Features

#
# HAL GPIO
#
# CONFIG_HAL_GPIO_PORT_ENUM is not set
CONFIG_HAL_GPIO_ESP32=y
# CONFIG_HAL_GPIO_STM32 is not set
# CONFIG_HAL_GPIO_CH32 is not set
# end of HAL GPIO

#
# Runtime Capacity
#
CONFIG_EVENT_BUS_QUEUE_LEN=64
CONFIG_EVENT_BUS_MAX_SUBSCRIBERS=24
CONFIG_EVENT_BUS_DISPATCH_STACK=2048
CONFIG_OSAL_MUTEX_POOL_SIZE=24
CONFIG_BOARD_STACK_MONITOR_MAX_TASKS=8
# end of Runtime Capacity

#
# Compiler Compatibility
#
CONFIG_COMPILER_GNU_EXTENSIONS=y
CONFIG_COMPILER_WARN_UNUSED_RESULT=y
# end of Compiler Compatibility

#
# Build Options
#
CONFIG_BUILD_DISASM=y
# end of Build Options
# end of mini_tree Configuration
